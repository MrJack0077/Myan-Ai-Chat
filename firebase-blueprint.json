{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["ADMIN", "VENDOR"] },
        "shopId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Vendor shop configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "provisioning", "inactive"] },
        "sendpulseBotIds": { "type": "array", "items": { "type": "string" } },
        "sendpulseBots": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "channel": { "type": "string" } } } },
        "sendpulseClientId": { "type": "string" },
        "sendpulseClientSecret": { "type": "string" },
        "databaseName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" },
        "aiConfig": { "type": "object" },
        "vendorCredentials": { "type": "object" }
      },
      "required": ["name", "slug", "status", "databaseName", "createdAt"]
    },
    "VendorItem": {
      "title": "VendorItem",
      "description": "Product or service item in a shop",
      "type": "object",
      "properties": {
        "item_type": { "type": "string", "enum": ["product", "service"] },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "stock_type": { "type": "string", "enum": ["count", "status"] },
        "stock_quantity": { "type": "number" },
        "is_available": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["item_type", "name", "price", "category", "status", "created_at"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "shippingAddress": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "customerName", "customerPhone", "items", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Shop category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Shop FAQ",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["question", "answer", "category"]
    },
    "BotUser": {
      "title": "BotUser",
      "description": "Bot customer / end-user",
      "type": "object",
      "properties": {
        "contact_id": { "type": "string" },
        "name": { "type": "string" },
        "channel": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["contact_id", "channel"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A support chat message",
      "type": "object",
      "properties": {
        "sender": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "senderRole": { "type": "string", "enum": ["VENDOR", "ADMIN"] },
        "isRead": { "type": "boolean" }
      },
      "required": ["sender", "text", "senderRole", "isRead", "timestamp"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A support chat session summary",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "number" }
      },
      "required": ["shopId", "lastMessage", "lastTimestamp", "unreadCount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Shop configurations"
    },
    "/shops/{shopId}/items/{itemId}": {
      "schema": "VendorItem",
      "description": "Shop inventory items"
    },
    "/shops/{shopId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders specific to a shop"
    },
    "/shops/{shopId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "Shop categories"
    },
    "/shops/{shopId}/faqs/{faqId}": {
      "schema": "FAQ",
      "description": "Shop FAQs"
    },
    "/bot_users/{userId}": {
      "schema": "BotUser",
      "description": "Customers communicating through AI bots"
    },
    "/support_sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Support chat sessions"
    },
    "/support_chats/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Support chat messages"
    }
  }
}
